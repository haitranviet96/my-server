{
	admin 0.0.0.0:2019

	acme_dns cloudflare {$CLOUDFLARE_API_TOKEN}

	dynamic_dns {
		provider cloudflare {
			api_token {$CLOUDFLARE_API_TOKEN}
		}

		domains {
			haivita.top *
			haivita.top @
		}

		check_interval 15m
		ttl 15m
	}
}

(cloudflare_site) {
	header -Server
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
}

disk.haivita.top {
	import cloudflare_site
	basic_auth {
		{$caddyfile_auth_user} {$caddyfile_auth_pass}
	}
	reverse_proxy scrutiny:8080
}

glances.haivita.top {
	import cloudflare_site
	basic_auth {
		{$caddyfile_auth_user} {$caddyfile_auth_pass}
	}
	reverse_proxy host.docker.internal:61208
}

mon.haivita.top {
	import cloudflare_site
	basic_auth {
		{$caddyfile_auth_user} {$caddyfile_auth_pass}
	}
	reverse_proxy host.docker.internal:19999
}

vault.haivita.top {
	import cloudflare_site
	reverse_proxy vaultwarden {
		header_up X-Real-IP {remote_host}
	}
}

frigate.haivita.top {
	import cloudflare_site
	reverse_proxy host.docker.internal:8971 {
		header_up Host {host}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		transport http {
			tls_insecure_skip_verify
		}
	}
}

*.haivita.top, haivita.top {
	import cloudflare_site

	# Root domain logic
	@root host haivita.top
	handle @root {
		reverse_proxy homepage:3000
	}

	# Subdomain mapping logic
	@sub host *.haivita.top
	handle @sub {
		map {host} {upstream} {
			speed.haivita.top speedtest-tracker:80
			blog.haivita.top ghost:2368
			file.haivita.top filebrowser:8080
			image.haivita.top immich_server:2283
			jellyfin.haivita.top jellyfin:8096
			radarr.haivita.top radarr:7878
			sonarr.haivita.top sonarr:8989
			bazarr.haivita.top bazarr:6767
			jellyseerr.haivita.top jellyseerr:5055
			prowlarr.haivita.top prowlarr:9696
			qbit.haivita.top qbittorrent:8080
			up.haivita.top uptime-kuma:3001
			portainer.haivita.top portainer:9000
			wud.haivita.top wud:3000
			home.haivita.top 192.168.1.144:8123
		}

		@has_upstream expression `{upstream} != ""`
		handle @has_upstream {
			reverse_proxy {upstream}
		}

		# Fallback for subdomains not in the map
		handle {
			respond "Subdomain not configured" 404
		}
	}
}
